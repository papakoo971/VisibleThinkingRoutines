# Firebase Web App config.
# Copy this file to .env.local and fill these values from Firebase Console > Project settings > Your apps.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Optional for server-side Firebase Admin SDK outside Google-managed runtimes.
# Keep this secret and never expose it with a NEXT_PUBLIC_ prefix.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Vercel AI Gateway. On Vercel, prefer automatically refreshed OIDC; use an API key for local development.
AI_GATEWAY_API_KEY=
AI_ANALYSIS_MODEL=openai/gpt-5.4

# Firebase SQL Connect emulator.
# Keep false for the live Firebase SQL Connect service.
NEXT_PUBLIC_FIREBASE_DATACONNECT_EMULATOR=false
NEXT_PUBLIC_FIREBASE_DATACONNECT_EMULATOR_HOST=localhost
NEXT_PUBLIC_FIREBASE_DATACONNECT_EMULATOR_PORT=9399

# Server-side created activity store.
# Use memory until Firebase SQL Connect is provisioned and migrated.
CREATED_ACTIVITY_STORE=memory
